project_name: {{ project_name }}
max_teammates: 5
playbook_mode: guide
lead_cli: claude   # S11+ may add codex / antigravity
allowed_personas:
  - planner
  - implementer
  - reviewer
  - tester
default_playbook: new-feature

sandbox:
  implementer: workspace-write
  tester: workspace-write

forbidden_paths:
{% for path in forbidden_paths %}
  - {{ path }}
{% endfor %}

lead_context_files:
  - TEAM.md
  - README.md
  - .agent-team/playbooks/{playbook}.yaml
